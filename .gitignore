# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/
*.tsbuildinfo

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test & coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.rollup.cache/

# ─── OS & editor artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
*.suo
*.user
*.userosscache
