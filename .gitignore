# ─── VS Code (keep shared settings, ignore personal) ──────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
*.zip

